# GCP project ID (from Google Cloud Console)
GCP_PROJECT=your-gcp-project-id

# Path to GCP service account credentials JSON file
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# GCP region for Vertex AI (us-central1 supports Gemini 1.5 Pro)
GCP_LOCATION=us-central1

# Flask environment (development | production)
FLASK_ENV=development

# Backend port (default 8000 in dev)
PORT=8000

# Frontend: backend API URL — override per environment
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production-only: Vercel deployment URL for CORS allowlist (no trailing slash)
# VERCEL_URL=https://your-app.vercel.app
